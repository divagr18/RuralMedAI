# Parchee Edge backend environment
#
# Copy this file to `backend/.env` for local uvicorn runs.

# Database / encryption
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ruralmed
AES_256_KEY=replace_with_base64_32byte_key

# Local Gemma 4 inference through llama.cpp
LLAMA_CPP_MODE=auto
LLAMA_CPP_BASE_URL=http://127.0.0.1:8080
LLAMA_CPP_MODEL_NAME=gemma-4
LLAMA_CPP_TIMEOUT_SECONDS=180
LLAMA_CPP_MAX_TOKENS=512
LLAMA_CPP_SUMMARY_MAX_TOKENS=384

# Adaptive voice activity detection
PARCHEE_CHUNK_SECONDS=10
PARCHEE_MIN_RMS=180
PARCHEE_VAD_FRAME_MS=250
PARCHEE_VAD_START_MS=300
PARCHEE_VAD_END_SILENCE_MS=900
PARCHEE_MAX_SPEECH_SECONDS=12
PARCHEE_MIN_SPEECH_MS=700

# Backend-managed llama-server startup
LLAMA_SERVER_AUTOSTART=true
LLAMA_SERVER_HOST=127.0.0.1
LLAMA_SERVER_PORT=8080
LLAMA_SERVER_BINARY=llama_cpp/bin/llama-server.exe
LLAMA_SERVER_MODEL=llama_cpp/models/gemma-4.gguf
LLAMA_SERVER_MMPROJ=llama_cpp/models/mmproj.gguf
LLAMA_SERVER_DOWNLOAD_MODELS=true
LLAMA_SERVER_MODEL_URL=https://huggingface.co/unsloth/gemma-4-E2B-it-GGUF/resolve/main/gemma-4-E2B-it-Q4_K_M.gguf?download=true
LLAMA_SERVER_MMPROJ_URL=https://huggingface.co/unsloth/gemma-4-E2B-it-GGUF/resolve/main/mmproj-BF16.gguf?download=true
LLAMA_SERVER_CHAT_TEMPLATE=llama_templates/gemma4_no_think.jinja
LLAMA_SERVER_CTX_SIZE=2048
LLAMA_SERVER_THREADS=4

# Put GPU/runtime flags here. Good Windows CUDA default:
# LLAMA_SERVER_EXTRA_ARGS=-ngl 999
LLAMA_SERVER_EXTRA_ARGS=

# CLI fallback only. Usually leave empty if llama-server audio works.
LLAMA_CPP_CLI_PATH=
LLAMA_CPP_CLI_ARGS=
LLAMA_CPP_THREADS=4
